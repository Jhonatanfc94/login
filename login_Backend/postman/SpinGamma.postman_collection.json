  "item": [
    {
      "name": "register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 201 - Registro exitoso\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Genera un número aleatorio para tener un usuario único cada vez\r",
              "let randomNum = Math.floor(Math.random() * 10000);\r",
              "let testUsername = \"usuario_test_\" + randomNum;\r",
              "\r",
              "// Guarda el nombre generado en una variable de colección llamada 'test_user'\r",
              "pm.collectionVariables.set(\"test_user\", testUsername);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"{{test_user}}\",\r\n    \"password\": \"PasswordSegura123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://127.0.0.1:5000/register",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "5000",
          "path": [
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "register duplicated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 400 - Usuario ya existe\", function () {\r",
              "    pm.response.to.have.status(400);\r",
              "});\r",
              "\r",
              "pm.test(\"Mensaje de error es correcto\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.message).to.eql(\"El usuario ya existe\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
