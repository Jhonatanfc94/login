    {
      "name": "login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 200 - Login exitoso\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Mensaje de éxito y usuario presentes\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.message).to.eql(\"Login exitoso\");\r",
              "\r",
              "    // También validamos que el backend nos devuelva el nombre de usuario\r",
              "    pm.expect(jsonData.user.username).to.eql(pm.collectionVariables.get(\"test_user\"));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"{{test_user}}\",\r\n    \"password\": \"PasswordSegura123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://127.0.0.1:5000/login",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "5000",
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "New Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 200 - Eliminación exitosa\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Mensaje de confirmación correcto\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.message).to.eql(\"Usuario eliminado con éxito\");\r",
              "});\r",
              "\r",
              "// Limpiamos la variable para no ensuciar el entorno de Postman\r",
              "pm.collectionVariables.unset(\"test_user\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://127.0.0.1:5000/user/{{test_user}}",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "5000",
          "path": [
            "user",
            "{{test_user}}"
          ]
        }
      },
      "response": []
    }
